# ══════════════════════════════════════════════════════════════════
#  Tomchi Tech — Environment Variables Template
#  Nusxa oling: cp .env.example .env
#  Keyin .env faylini to'ldiring va hech qachon git ga qo'shmang!
# ══════════════════════════════════════════════════════════════════

# ── Asosiy API ────────────────────────────────────────────────────
TOMCHI_API_URL=https://tomchi-tech-api.onrender.com/api/v1
TOMCHI_API_KEY=

# ── Telegram Bot ──────────────────────────────────────────────────
BOT_TOKEN=
WEBHOOK_URL=
BOT_ALERTS_SECRET=change-this-to-random-secret
BOT_ALERTS_PORT=8787

# ── MyID (my.gov.uz) — Biometrik identifikatsiya ──────────────────
# Ro'yxatdan o'tish: https://developers.myid.uz
MYID_CLIENT_ID=
MYID_CLIENT_SECRET=
MYID_SANDBOX=true            # true=test, false=ishlab turgan

# ── Yer Kadastr (kadastr.uz) ──────────────────────────────────────
# API kaliti: https://api.kadastr.uz
KADASTR_TOKEN=
KADASTR_BASE_URL=https://api.kadastr.uz/v1

# ── Qishloq xo'jaligi vazirligi (agro.uz) ─────────────────────────
# API kaliti: https://api.agro.uz
AGRO_TOKEN=
AGRO_BASE_URL=https://api.agro.uz/v1

# ── E-hukumat (egov.uz) ───────────────────────────────────────────
# API kaliti: https://api.egov.uz
EGOV_API_KEY=
EGOV_BASE_URL=https://api.egov.uz/v1

# ── Soliq qo'mitasi (soliq.uz) ────────────────────────────────────
# API kaliti: https://api.soliq.uz
SOLIQ_TIN=                   # Korxona INN (STIR)
SOLIQ_TOKEN=

# ─────────────────────────────────────────────────────────────────
#  TO'LOV TIZIMLARI
# ─────────────────────────────────────────────────────────────────

# ── Payme (payme.uz) — #1 to'lov tizimi ──────────────────────────
# Ro'yxat: https://merchant.paycom.uz
PAYME_MERCHANT_ID=
PAYME_SECRET_KEY=
PAYME_TEST_MODE=true         # false qilib production ga o'ting

# ── Click (click.uz) ──────────────────────────────────────────────
# Ro'yxat: https://my.click.uz/services/add
CLICK_MERCHANT_ID=
CLICK_SERVICE_ID=
CLICK_SECRET_KEY=
CLICK_TEST_MODE=true

# ── Uzum Bank (uzumbank.uz) ───────────────────────────────────────
# Ro'yxat: https://developers.uzumbank.uz
UZUM_SHOP_ID=
UZUM_TOKEN=
UZUM_TEST_MODE=true

# ─────────────────────────────────────────────────────────────────
#  BACKEND / DATABASE
# ─────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./tomchi.db
# PostgreSQL uchun:
# DATABASE_URL=postgresql://user:password@localhost:5432/tomchi_db

# ── Security ──────────────────────────────────────────────────────
SECRET_KEY=change-this-to-a-very-long-random-string-in-production
ALLOWED_HOSTS=*
DEBUG=false
CORS_ORIGINS=https://tomchi-tech.onrender.com
